//c
#include <stdio.h>

int main() {
    int T;
    // Read the number of test cases
    if (scanf("%d", &T) != 1) return 0;

    while (T--) {
        int X, Y;
        // Read X (number of 1s) and Y (number of 2s)
        if (scanf("%d %d", &X, &Y) != 2) break;

        // Print the first half of 1s
        for (int i = 0; i < X / 2; i++) {
            printf("1");
        }

        // Print all the 2s in the middle
        for (int i = 0; i < Y; i++) {
            printf("2");
        }

        // Print the second half of 1s to complete the palindrome
        for (int i = 0; i < X / 2; i++) {
            printf("1");
        }

        // Move to the next line for the next test case
        printf("\n");
    }

    return 0;
}

//python
# cook your dish here
import sys

def solve():
    # Read the number of test cases
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    T = int(input_data[0])
    idx = 1
    
    for _ in range(T):
        X = int(input_data[idx])
        Y = int(input_data[idx + 1])
        idx += 2
        
        # Calculate half of X
        half_x = X // 2
        
        # Construct the palindrome: 
        # half of 1s + all 2s + half of 1s
        result = ('1' * half_x) + ('2' * Y) + ('1' * half_x)
        
        print(result)

if __name__ == "__main__":
    solve()
