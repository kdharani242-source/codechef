#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int x,y,z;
	    scanf("%d %d %d",&x,&y,&z);
	    if(x*y<=z){
	        printf("%d\n",0);
	    }
	    else{
	        int excess_amount=(x*y)-z;
	        int sourcess_reduce=(excess_amount+y-1)/y;
	        printf("%d\n",sourcess_reduce);
	    }
	}

}

