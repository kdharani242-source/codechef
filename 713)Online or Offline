int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int n,m;
	    scanf("%d %d",&n,&m);
	    if(n-(n*0.1)<m){
	        printf("online\n");
	    }
	    else if(n-(n*0.1)>m){
	        printf("dining\n");
	    }
	    else{
	        printf("either\n");
	    }
	}

}

