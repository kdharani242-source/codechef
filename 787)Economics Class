//c
#include <stdio.h>

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while(t--) {
        int n;
        scanf("%d", &n);
        int s[n], d[n];
        
        // Read the supply array
        for(int i = 0; i < n; i++) {
            scanf("%d", &s[i]);
        }
        
        // Read the demand array
        for(int i = 0; i < n; i++) {
            scanf("%d", &d[i]);
        }
        
        // Compare elements
        int count = 0;
        for(int i = 0; i < n; i++) {
            if(s[i] == d[i]) {
                count++;
            }
        }
        printf("%d\n", count);
    }
    return 0;
}

