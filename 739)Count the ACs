//c
#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int n;
	    scanf("%d",&n);
	    int num1=n/100;
	    int num2=n%100;
	    if(num1+num2<=10){
	        printf("%d\n",num1+num2);
	    }
	    else{
	        printf("%d\n",-1);
	    }
	}

}

//python
# cook your dish here
t=int(input())
for _ in range(t):
    P = int(input())
    
    # Number of 100-point problems solved
    num_100 = P // 100
    # Number of 1-point problems solved
    num_1 = P % 100
    
    total_solved = num_100 + num_1
    
    # The score is only valid if the total number of solved problems is 10 or less.
    if total_solved <= 10:
        print(total_solved)
    else:
        # This catches cases like P=142 (X=1, Y=42, total=43) or P=111 (X=1, Y=11, total=12)
        print(-1)
