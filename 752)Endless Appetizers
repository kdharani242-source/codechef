#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int x,y,r;
	    scanf("%d %d %d",&x,&y,&r);
	    int extra=r/30;
	    int total=x+extra;
	    int max_plates=(total+y-1)/y;
	    printf("%d\n",max_plates);
	}

}

