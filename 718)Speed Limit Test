int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int a,x,b,y;
	    scanf("%d %d %d %d",&a,&x,&b,&y);
	    if(a*y>b*x){
	        printf("alice\n");
	    }
	    else if(a*y<b*x){
	        printf("bob\n");
	    }
	    else{
	        printf("equal\n");
	    }
	}

}

