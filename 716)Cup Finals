#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int x,y,d;
	    scanf("%d %d %d",&x,&y,&d);
	    if(abs(x-y)<=d){
	        printf("yes\n");
	    }
	    else{
	        printf("no\n");
	    }
	}

}

