#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int n;
	    scanf("%d",&n);
	    int arr[n];
	    int count=0;
	    for(int i=0;i<n;i++){
	        scanf("%d",&arr[i]);
	        if(arr[i]%2==0){
	            count+=arr[i]/2;
	        }
	        else{
	            count+=(arr[i]/2)+1;
	        }
	    }
	    printf("%d\n",count);
	}

}

