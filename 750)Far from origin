//c
#include <stdio.h>

int main() {
	int t;
	scanf("%d",&t);
	while(t--){
	    long long x1, y1, x2, y2; // Using long long just in case, though int should suffice given constraints
	    scanf("%lld %lld %lld %lld",&x1,&y1,&x2,&y2);
	    
        // Correct way to calculate squared distance: multiply the number by itself.
	    long long dist_alex_sq = (x1 * x1) + (y1 * y1);
	    long long dist_bob_sq = (x2 * x2) + (y2 * y2);
	    
	    if(dist_alex_sq < dist_bob_sq){
	        printf("BOB\n"); // Output matches required uppercase format
	    }
	    else if(dist_alex_sq > dist_bob_sq){
	        printf("ALEX\n"); // Output matches required uppercase format
	    }
	    else{
	        printf("EQUAL\n"); // Output matches required uppercase format
	    }
	}
    return 0;
}

//python
# cook your dish here
def solve():
    x1, y1, x2, y2 = map(int, input().split())

    dist_alex_sq = x1**2 + y1**2
    dist_bob_sq = x2**2 + y2**2

    if dist_alex_sq > dist_bob_sq:
        print("ALEX")
    elif dist_bob_sq > dist_alex_sq:
        print("BOB")
    else:
        print("EQUAL")

t = int(input())
for _ in range(t):
    solve()
