//c
#include <stdio.h>

int main() {
    int x;
    // Read the rank
    if (scanf("%d", &x) == 1) {
        /* 
           In C, (1 << (4 - x)) calculates 2 raised to the power of (4 - x).
           For example:
           If x = 1, 1 << 3 = 8
           If x = 4, 1 << 0 = 1
        */
        int prize = 1000 * (1 << (4 - x));
        printf("%d\n", prize);
    }
    return 0;
}


