int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int n;
	    scanf("%d",&n);
	    if(n>=4){
	        printf("%d\n",(n*3)-3);
	    }
	    else{
	        printf("%d\n",-1);
	    }
	}

}

