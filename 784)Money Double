int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int x,y;
	    scanf("%d %d",&x,&y);
	    int count=x;
	    for(int i=0;i<y;i++){
	        if(count*2<count+1000){
	            count+=1000;
	        }
	        else{
	            count*=2;
	        }
	    }
	    printf("%d\n",count);
	}

}

