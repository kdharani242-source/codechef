#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

int main() {
    int t;
    // Read the number of test cases
    if (scanf("%d", &t) != 1) return 0;

    while (t--) {
        int n, a, b;
        // Read N, A, and B
        scanf("%d %d %d", &n, &a, &b);

        int min_dist = INT_MAX; // Initialize with the maximum possible integer value

        for (int i = 0; i < n; i++) {
            int x, y;
            // Read coordinates of each attraction
            scanf("%d %d", &x, &y);

            // Manhattan distance formula: |A - X| + |B - Y|
            int current_dist = abs(a - x) + abs(b - y);

            // Check if this is the smallest distance found so far
            if (current_dist < min_dist) {
                min_dist = current_dist;
            }
        }

        // Print the result for the current test case
        printf("%d\n", min_dist);
    }

    return 0;
}




