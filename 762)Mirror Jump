//c
#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int n,k;
	    scanf("%d %d",&n,&k);
	    if(k<=n/2){
	        printf("%d\n",k);
	    }
	    else{
	        printf("%d\n",n-k);
	    }
	}

}

