//c
#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int n;
	    scanf("%d",&n);
	    if(n%10==0){
	        printf("%d\n",(n/10));
	    }
	    else if(n%5==0){
	        printf("%d\n",(n/10)+1);
	    }
	    else{
	        printf("%d\n",-1);
	    }
	}

}

