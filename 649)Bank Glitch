//c
#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int a,b,x,y;
	    scanf("%d %d %d %d",&a,&b,&x,&y);
	    while(a>=x){
	        a-=x;
	        b+=y;
	    }
	    printf("%d\n",a+b);
	}

}

