#include <stdio.h>

int main() {
    int t;
    // Read the number of test cases
    if (scanf("%d", &t) != 1) return 0;
    
    while (t--) {
        int x, y, z;
        // Read X, Y, Z for each test case
        if (scanf("%d %d %d", &x, &y, &z) == 3) {
            // Check if current points + max possible points (2 per game) >= Y
            if (x + (2 * z) >= y) {
                printf("YES\n");
            } else {
                printf("NO\n");
            }
        }
    }
    return 0;
}
