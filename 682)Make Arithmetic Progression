//c
#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int x,y,z;
	    scanf("%d %d %d",&x,&y,&z);
	    if(y-x==z-y){
	        printf("%d\n",0);
	    }
	    else{
	        printf("%d\n",1);
	    }
	}
}

