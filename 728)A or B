#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int a,b;
	    scanf("%d %d",&a,&b);
	    int a_max=(500-(a*2))+(1000-((a+b)*4));
	    int b_max=(1000-(b*4))+(500-((a+b)*2));
	    if(a_max>b_max){
	        printf("%d\n",a_max);
	    }
	    else{
	        printf("%d\n",b_max);
	    }
	}

}

