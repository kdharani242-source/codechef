//c
#include <stdio.h>

void solve() {
    int n, a, b;
    // Read N, A, and B for the current test case
    if (scanf("%d %d %d", &n, &a, &b) != 3) return;

    int count = 0;
    int wearing_jacket = 0; // 0 = False, 1 = True (Initially not wearing)

    for (int i = 0; i < n; i++) {
        int temp;
        scanf("%d", &temp);

        if (temp < a) {
            // Chef MUST wear a jacket
            if (wearing_jacket == 0) {
                count++;
                wearing_jacket = 1;
            }
        } else if (temp > b) {
            // Chef MUST remove the jacket
            wearing_jacket = 0;
        }
        // If a <= temp <= b, Chef stays in his current state
    }

    printf("%d\n", count);
}

int main() {
    int t;
    // Read the number of test cases
    if (scanf("%d", &t) != 1) return 0;

    while (t--) {
        solve();
    }

    return 0;
}

