import sys

def solve_case_analysis():
    # Fast reading for competitive programming context
    input = sys.stdin.read().split()
    if not input:
        return
        
    T = int(input[0])
    results = []
    
    # Pointer to read N values
    input_ptr = 1

    for _ in range(T):
        N = int(input[input_ptr])
        input_ptr += 1
        
        is_divisible_by_2 = (N % 2 == 0)
        is_divisible_by_5 = (N % 5 == 0)
        
        # Case 1: N is already imperfect (Divisible by 2 XOR 5)
        if (is_divisible_by_2 or is_divisible_by_5) and not (is_divisible_by_2 and is_divisible_by_5):
            # N is imperfect itself (e.g., 2, 5, 8, 14)
            results.append(0)
            
        # Case 2: N is divisible by both 2 and 5 (i.e., divisible by 10)
        elif is_divisible_by_2 and is_divisible_by_5:
            # Closest imperfect numbers are N-2 (divisible by 2 only, if N>=2) or N+2 (divisible by 2 only, if N+2 not div by 5).
            # Since N is a multiple of 10, N-2 is div by 2 but not 5. N+2 is div by 2 but not 5.
            # The minimum difference is 2.
            results.append(2)
            
        # Case 3: N is divisible by neither 2 nor 5
        else: # not is_divisible_by_2 and not is_divisible_by_5
            # N+1 is guaranteed to be divisible by 2 (if N is odd) or N+1 is divisible by 5 (if N ends in 4 or 9).
            # If N is odd (e.g., 1, 3, 7, 9), N+1 is even (imperfect). Diff = 1.
            # If N ends in 4 (e.g., 4, 14 - wait, 14 is div by 2, this case doesn't apply to 4), N is not div by 2 or 5.
            # If N ends in 1, 3, 7, 9: N+1 is even, so N+1 is imperfect. Diff = 1.
            # Example N=9: 8 is imperfect (|9-8|=1). 10 is not imperfect. 11 is not imperfect. 12 is imperfect (|9-12|=3). Min diff is 1.
            # If N is not divisible by 2 or 5, then N+1 or N-1 must be imperfect, yielding a difference of 1.
            results.append(1)

    sys.stdout.write('\n'.join(map(str, results)) + '\n')

solve_case_analysis()
