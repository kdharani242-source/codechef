//c
#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int s,x,y,z;
	    scanf("%d %d %d %d",&s,&x,&y,&z);
	    if(s-(x+y)>=z){
	        printf("%d\n",0);
	    }
	    else if(s-x>=z || s-y>=z){
	        printf("%d\n",1);
	    }
	    else{
	        printf("%d\n",2);
	    }
	}

}

