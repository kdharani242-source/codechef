	int t;
	scanf("%d",&t);
	while(t--){
	    int n,k;
	    scanf("%d %d",&n,&k);
	    int min=10*n;
	    int max=12*n;
	    if(k>=min && k<=max){
	        printf("yes\n");
	    }
	    else{
	        printf("no\n");
	    }
	}

}

