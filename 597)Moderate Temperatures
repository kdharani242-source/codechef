# cook your dish here
import sys

def solve():
    # Read the number of test cases
    t = int(sys.stdin.readline())
    for _ in range(t):
        n = int(sys.stdin.readline())
        a = list(map(int, sys.stdin.readline().split()))
        
        # Find the global min and max temperatures
        mn = min(a)
        mx = max(a)
        
        # Count days that are neither the minimum nor the maximum
        ans = 0
        for temp in a:
            if temp != mn and temp != mx:
                ans += 1
        
        print(ans)

if __name__ == '__main__':
    solve()
