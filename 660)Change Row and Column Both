#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int a,b,c,d;
	    scanf("%d %d %d %d",&a,&b,&c,&d);
	    if(a!=c && b!=d){
	        printf("%d\n",1);
	    }
	    else{
	        printf("%d\n",2);
	    }
	}

}

