#include <stdio.h>

int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int n;
	    scanf("%d",&n);
	    if(n<2){
	        printf("%d\n",0);
	    }
	    else{
	        printf("%d\n",(((n-2)/7)+1));
	    }
	}

}

