int main() {
	// your code goes here
	int t;
	scanf("%d",&t);
	while(t--){
	    int n,x,p;
	    scanf("%d %d %d",&n,&x,&p);
	    if((3*x)-(n-x)>=p){
	        printf("pass\n");
	    }
	    else{
	        printf("fail\n");
	    }
	}

}

